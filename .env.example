# ─────────────────────────────────────────────────────────────────────────────
# RageBot MCP — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── MCP Server Config ────────────────────────────────────────────────────────
# Used when running the MCP server
RAGEBOT_MCP_TRANSPORT=stdio
RAGEBOT_MCP_HOST=127.0.0.1
RAGEBOT_MCP_PORT=8765

# ── Context Settings ─────────────────────────────────────────────────────────
RAGEBOT_CONTEXT_WINDOW_TURNS=3
RAGEBOT_CONTEXT_CACHE_ENABLED=true
