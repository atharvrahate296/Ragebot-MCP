# ─────────────────────────────────────────────────────────────────────────────
# RageBot MCP — Environment Variables
# Copy this file to .env and fill in your values, OR use `rage auth login`
# which stores keys securely in your OS keyring (recommended).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | grok | none
RAGEBOT_LLM_PROVIDER=gemini

# ── API Keys (alternative to `rage auth login`) ───────────────────────────────
# Google Gemini — get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# xAI Grok — get key at: https://console.x.ai
GROK_API_KEY=your-grok-api-key-here

# ── Embedding Model ───────────────────────────────────────────────────────────
# sentence-transformers model name (downloaded automatically on first use ~90 MB)
RAGEBOT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── MCP Server (for `rage mcp start --transport sse`) ────────────────────────
RAGEBOT_MCP_TRANSPORT=stdio
RAGEBOT_MCP_HOST=127.0.0.1
RAGEBOT_MCP_PORT=8765
